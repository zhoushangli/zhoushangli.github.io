---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
---

<PortfolioLayout
	title="Individual Work | ShangLi Zhou"
	description="DFS I individual work by ShangLi Zhou, with placeholder static and animated media."
>
	<section class="page-hero">
		<p class="eyebrow" data-i18n="individual.eyebrow">Individual Work</p>
		<h1 data-i18n="individual.title">DFS I</h1>
		<p data-i18n="individual.intro">
			An individual project focused on gradually building a game engine and documenting the
			technical decisions behind the work.
		</p>
	</section>

	<section class="section">
		<div class="project-header">
			<div>
				<p class="section-label" data-i18n="individual.label">Project</p>
				<h2 data-i18n="individual.projectTitle">DFS I - Engine Foundation</h2>
			</div>
			<p class="tag" data-i18n="individual.tag">Individual Project</p>
		</div>
		<div class="copy-block wide">
			<p data-i18n="individual.description">
				DFS I is a placeholder portfolio entry for an individual engine-development project. The
				final version will show how I approach rendering, input, update loops, asset handling, and
				small gameplay tests as the engine grows from a technical base into a playable environment.
			</p>
		</div>
	</section>

	<section class="section media-grid">
		<article class="card media-card">
			<img
				src="/images/dfs-static-placeholder.svg"
				alt="DFS I static image placeholder"
				data-i18n-alt="individual.staticAlt"
			/>
			<h3 data-i18n="individual.staticTitle">Static Image</h3>
			<p data-i18n="individual.staticDescription">
				This placeholder will be replaced by a still screenshot of the DFS I engine or prototype
				state.
			</p>
		</article>
		<article class="card media-card">
			<img
				src="/images/dfs-animated-placeholder.svg"
				alt="DFS I animated image placeholder"
				data-i18n-alt="individual.animatedAlt"
			/>
			<h3 data-i18n="individual.animatedTitle">Animated Image</h3>
			<p data-i18n="individual.animatedDescription">
				This placeholder will be replaced by a GIF or animated capture showing the project in
				motion.
			</p>
		</article>
	</section>
</PortfolioLayout>
