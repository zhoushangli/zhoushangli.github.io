---
import { Image } from 'astro:assets';
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import HeroImage from '../content/images/hero_image.jpg';
import TencentImage from '../content/images/tencent.png';
import NuverseImage from '../content/images/nuverse.png';
import ShanghaiTechImage from '../content/images/shanghaitech.png';
import SmuImage from '../content/images/smu.png';
import { getProjectsByCategory } from '../data/projects';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const personalProjects = getProjectsByCategory('personal');
const teamProjects = getProjectsByCategory('team');
---

<PortfolioLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero hero-intro">
		<div class="hero-copy">
			<p class="eyebrow" data-i18n="home.heroEyebrow">ShangLi Zhou</p>
			<h1 class="hero-title" data-i18n="home.heroTitle">Hi, I'm ShangLi</h1>
			<p class="subtitle" data-i18n="home.heroSubtitle">I'm a Game Developer.</p>
			<p class="hero-intro-text" data-i18n="home.heroIntro">
				I'm currently studying Game Software Development at SMU Guildhall. I previously studied
				Computer Science at ShanghaiTech University. XXXXXXXXXXXXX.
			</p>
			<p class="contact-line" data-i18n="home.contactLine">
				I reply fastest on email: XXXXXXXXXXXXX
			</p>
		</div>
	</section>

	<section class="section about-profile" id="about">
		<p class="section-label" data-i18n="home.aboutLabel">About</p>
		<h2 data-i18n="home.aboutSecondTitle">Hi, I'm ShangLi</h2>
		<div class="about-profile-grid">
			<Image
				class="hero-image profile-image"
				src={HeroImage}
				alt="Portrait image of ShangLi Zhou"
				data-i18n-alt="home.heroAlt"
				format="webp"
				quality={82}
				widths={[480, 720, 960]}
				sizes="(max-width: 860px) 100vw, 38vw"
			/>
			<div class="copy-block">
				<div class="bio-copy" data-i18n-html="home.aboutSecondBody">
					<p>
						I'm currently studying game development at SMU Guildhall, where I'm building a custom
						game engine with DirectX11. I've also worked on a 50-person Unreal Engine team to
						develop and ship a Mario Kart-like racing game on Steam.
					</p>
					<p>
						I'm passionate about content creation, small animals, and
						<u title="Just a joke, please don't take it seriously">starting foreign wars</u>. I have
						nearly 600 hours in Victoria 3, which has made me especially interested in modernization,
						modernity, and the historical systems that shape China and the wider world.
					</p>
					<p>
						Although my main discipline is programming, I also study level design. I've written
						breakdowns of Ori and the Will of the Wisps and Celeste, and recreated a level from
						Uncharted 4 to better understand pacing, space, traversal, and encounter design.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section timeline-section" id="experience">
		<h2 data-i18n-inline data-en="Experience" data-zh="经历">Experience</h2>
		<div class="timeline-list">
			<article class="timeline-item">
				<div class="timeline-media">
					<Image
						src={TencentImage}
						alt="Tencent MoreFun Studios logo"
						width={420}
						format="webp"
						quality={84}
					/>
				</div>
				<div class="timeline-meta">
					<p class="timeline-date">Jan 2024 - Feb 2024</p>
					<h3 data-i18n-inline data-en="Tencent MoreFun Studios" data-zh="腾讯魔方工作室群">
						Tencent MoreFun Studios
					</h3>
					<p data-i18n-inline data-en="Combat Designer Intern" data-zh="战斗策划实习生">
						Combat Designer Intern
					</p>
				</div>
				<div class="timeline-copy">
					<p
						data-i18n-inline
						data-en="I configured in-game audio and enemy combat animations as a combat designer at Tencent MoreFun Studios."
						data-zh="我在腾讯魔方工作室群担任战斗策划实习生，主要负责游戏音效配置和敌人战斗动画配置。">
						I configured in-game audio and enemy combat animations as a combat designer at
						Tencent MoreFun Studios.
					</p>
					<p class="timeline-tech">Combat Design | Audio | Enemy Animation</p>
				</div>
			</article>

			<article class="timeline-item">
				<div class="timeline-media">
					<Image src={NuverseImage} alt="Nuverse logo" width={420} format="webp" quality={84} />
				</div>
				<div class="timeline-meta">
					<p class="timeline-date">Aug 2023 - Dec 2023</p>
					<h3
						data-i18n-inline
						data-en="Nuverse"
						data-zh="朝夕光年">Nuverse</h3
					>
					<p
						data-i18n-inline
						data-en="Software Development Intern"
						data-zh="软件开发">Software Development Intern</p
					>
				</div>
				<div class="timeline-copy">
					<p
						data-i18n-inline
						data-en="I worked as a frontend developer at Nuverse, using PyQt to support engine toolchain development."
						data-zh="我在朝夕光年担任前端开发，使用 PyQt 辅助引擎工具链开发。">
						I worked as a frontend developer at Nuverse, using PyQt to support engine toolchain
						development.
					</p>
					<p class="timeline-tech">Unity | PyQt</p>
				</div>
			</article>
		</div>
	</section>

	<section class="section timeline-section" id="education">
		<h2 data-i18n-inline data-en="Education" data-zh="教育经历">Education</h2>
		<div class="timeline-list">
			<article class="timeline-item">
				<div class="timeline-media">
					<Image
						src={ShanghaiTechImage}
						alt="ShanghaiTech University logo"
						width={420}
						format="webp"
						quality={84}
					/>
				</div>
				<div class="timeline-meta">
					<p class="timeline-date">2021 - 2025</p>
					<h3
						data-i18n-inline
						data-en="ShanghaiTech University"
						data-zh="上海科技大学">ShanghaiTech University</h3
					>
					<p
						data-i18n-inline
						data-en="B.S. in Computer Science"
						data-zh="计算机科学本科">B.S. in Computer Science</p
					>
				</div>
				<div class="timeline-copy">
					<p
						data-i18n-inline
						data-en="I studied computer science as an undergraduate, building a foundation in programming, systems, and software development."
						data-zh="我本科就读于计算机科学专业，建立了程序开发、系统和软件工程方面的基础。">
						I studied computer science as an undergraduate, building a foundation in programming,
						systems, and software development.
					</p>
					<p class="timeline-tech">Computer Science | Software Development</p>
				</div>
			</article>

			<article class="timeline-item">
				<div class="timeline-media">
					<Image src={SmuImage} alt="SMU Guildhall logo" width={420} format="webp" quality={84} />
				</div>
				<div class="timeline-meta">
					<p class="timeline-date">2025 - 2027</p>
					<h3 data-i18n-inline data-en="SMU Guildhall" data-zh="SMU Guildhall">SMU Guildhall</h3>
					<p
						data-i18n-inline
						data-en="Game Development Graduate Program"
						data-zh="游戏开发研究生课程">Game Development Graduate Program</p
					>
				</div>
				<div class="timeline-copy">
					<p
						data-i18n-inline
						data-en="I am currently studying game development, with a focus on engine programming, gameplay systems, and production practice."
						data-zh="我目前学习游戏开发研究生课程，关注引擎编程、玩法系统和制作实践。">
						I am currently studying game development, with a focus on engine programming,
						gameplay systems, and production practice.
					</p>
					<p class="timeline-tech">DirectX11 | Game Engine Programming</p>
				</div>
			</article>
		</div>
	</section>


	<section class="section showcase-section" id="personal-projects">
		<h2 data-i18n-inline data-en="Personal Projects" data-zh="个人项目">Personal Projects</h2>
		<div class="showcase-list">
			{
				personalProjects.map((project) => (
					<a class="showcase-card clickable-card" href={`/projects/${project.slug}`}>
						<div class="showcase-media">
							<img
								src={project.media.src}
								alt={project.media.alt.en}
								data-i18n-inline-alt
								data-en={project.media.alt.en}
								data-zh={project.media.alt.zh}
							/>
						</div>
						<div class="showcase-copy">
							<h3>{project.title}</h3>
							<p data-i18n-inline data-en={project.summary.en} data-zh={project.summary.zh}>
								{project.summary.en}
							</p>
							<p
								class="showcase-tech"
								data-i18n-inline
								data-en={project.tech.en}
								data-zh={project.tech.zh}>
								{project.tech.en}
							</p>
						</div>
					</a>
				))
			}
		</div>
	</section>

	<section class="section showcase-section" id="team-projects">
		<h2 data-i18n-inline data-en="Team Projects" data-zh="团队项目">Team Projects</h2>
		<div class="showcase-list">
			{
				teamProjects.map((project) => (
					<a class="showcase-card clickable-card" href={`/projects/${project.slug}`}>
						{project.media.type === 'image' ? (
							<div class="showcase-media">
								<img
									src={project.media.src}
									alt={project.media.alt.en}
									data-i18n-inline-alt
									data-en={project.media.alt.en}
									data-zh={project.media.alt.zh}
								/>
							</div>
						) : (
							<div class="showcase-media video-thumbnail">
								<div class="play-mark" aria-hidden="true" />
								<p>{project.title}</p>
							</div>
						)}
						<div class="showcase-copy">
							<h3>{project.title}</h3>
							<p data-i18n-inline data-en={project.summary.en} data-zh={project.summary.zh}>
								{project.summary.en}
							</p>
							<p
								class="showcase-tech"
								data-i18n-inline
								data-en={project.tech.en}
								data-zh={project.tech.zh}>
								{project.tech.en}
							</p>
						</div>
					</a>
				))
			}
		</div>
	</section>
</PortfolioLayout>
