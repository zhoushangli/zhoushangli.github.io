---
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
const usesStackedDetail = project.category === 'personal' || project.detailLayout === 'stacked';
---

<PortfolioLayout title={`${project.title} | ShangLi Zhou`} description={project.summary.en}>
	<section class="project-detail-hero">
		<p
			class="eyebrow"
			data-i18n-inline
			data-en={project.category === 'personal' ? 'Personal Project' : 'Team Project'}
			data-zh={project.category === 'personal' ? '个人项目' : '团队项目'}
		>
			{project.category === 'personal' ? 'Personal Project' : 'Team Project'}
		</p>
		<h1>{project.title}</h1>
		<p data-i18n-inline data-en={project.summary.en} data-zh={project.summary.zh}>
			{project.summary.en}
		</p>
		<p class="showcase-tech" data-i18n-inline data-en={project.tech.en} data-zh={project.tech.zh}>
			{project.tech.en}
		</p>
		{
			project.externalLink && (
				<div class="project-links">
					<a
						class="button secondary"
						href={project.externalLink.href}
						target="_blank"
						rel="noreferrer"
						data-i18n-inline
						data-en={project.externalLink.label.en}
						data-zh={project.externalLink.label.zh}>
						{project.externalLink.label.en}
					</a>
				</div>
			)
		}
	</section>

	<section class={`section project-detail-grid ${usesStackedDetail ? 'project-detail-stack' : ''}`}>
		<div class="project-detail-media">
			{
				project.media.type === 'video' ? (
					<div class="video-frame">
						<iframe
							src={project.media.src}
							title={project.media.alt.en}
							data-i18n-inline-title
							data-en={project.media.alt.en}
							data-zh={project.media.alt.zh}
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
						/>
					</div>
				) : (
					<img
						src={project.media.src}
						alt={project.media.alt.en}
						data-i18n-inline-alt
						data-en={project.media.alt.en}
						data-zh={project.media.alt.zh}
					/>
				)
			}
		</div>

		{
			project.embedVideo && (
				<div class="project-detail-video">
					<div class="video-frame">
						<iframe
							src={project.embedVideo.src}
							title={project.embedVideo.title.en}
							data-i18n-inline-title
							data-en={project.embedVideo.title.en}
							data-zh={project.embedVideo.title.zh}
							allow="autoplay; fullscreen; picture-in-picture"
							allowfullscreen
						/>
					</div>
				</div>
			)
		}

		{
			usesStackedDetail ? (
				<div class="project-detail-copy project-personal-copy">
					<h2 data-i18n-inline data-en="Introduction" data-zh="介绍">
						Introduction
					</h2>
					<div class="project-introduction-grid">
						<div>
							<p data-i18n-inline data-en={project.detail.en} data-zh={project.detail.zh}>
								{project.detail.en}
							</p>
						</div>
						<dl class="project-meta-list">
							{project.duration && (
								<div>
									<dt data-i18n-inline data-en="Duration:" data-zh="周期：">
										Duration:
									</dt>
									<dd>{project.duration}</dd>
								</div>
							)}
							<div>
								<dt data-i18n-inline data-en="Technologies:" data-zh="技术：">
									Technologies:
								</dt>
								<dd data-i18n-inline data-en={project.tech.en} data-zh={project.tech.zh}>
									{project.tech.en}
								</dd>
							</div>
							{project.role && (
								<div>
									<dt data-i18n-inline data-en="Role:" data-zh="职责：">
										Role:
									</dt>
									<dd data-i18n-inline data-en={project.role.en} data-zh={project.role.zh}>
										{project.role.en}
									</dd>
								</div>
							)}
						</dl>
					</div>

					<h2
						data-i18n-inline
						data-en={project.category === 'team' ? 'Key Contributions' : 'Key Features'}
						data-zh={project.category === 'team' ? '主要贡献' : '主要功能'}>
						{project.category === 'team' ? 'Key Contributions' : 'Key Features'}
					</h2>
					<ul class="project-feature-list">
						{project.features?.map((feature) => (
							<li data-i18n-inline data-en={feature.en} data-zh={feature.zh}>
								{feature.en}
							</li>
						))}
					</ul>
				</div>
			) : (
				<div class="project-detail-copy">
					<h2 data-i18n-inline data-en="Overview" data-zh="概览">
						Overview
					</h2>
					<p data-i18n-inline data-en={project.detail.en} data-zh={project.detail.zh}>
						{project.detail.en}
					</p>

					<h2 data-i18n-inline data-en="My Contribution" data-zh="我的贡献">
						My Contribution
					</h2>
					<p data-i18n-inline data-en={project.contribution.en} data-zh={project.contribution.zh}>
						{project.contribution.en}
					</p>
				</div>
			)
		}
	</section>
</PortfolioLayout>
