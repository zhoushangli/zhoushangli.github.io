---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import { GITHUB_URL, LINKEDIN_URL } from '../consts';
---

<PortfolioLayout
	title="Personal | ShangLi Zhou"
	description="Resume, cover letter, LinkedIn, and GitHub links for ShangLi Zhou."
>
	<section class="page-hero">
		<p class="eyebrow" data-i18n="personal.eyebrow">Personal</p>
		<h1 data-i18n="personal.title">Resume, Letter, and Profiles</h1>
		<p data-i18n="personal.intro">
			This page collects the required personal materials for the portfolio submission. Resume and
			cover letter PDFs are placeholders until final documents are added.
		</p>
	</section>

	<section class="section">
		<div class="grid two">
			<a class="card link-card" href="/documents/resume-placeholder.pdf" target="_blank">
				<p class="tag" data-i18n="personal.pdfTag">PDF Placeholder</p>
				<h2 data-i18n="personal.resumeTitle">Resume</h2>
				<p data-i18n="personal.resumeDescription">Placeholder resume PDF for portfolio submission.</p>
			</a>
			<a class="card link-card" href="/documents/cover-letter-placeholder.pdf" target="_blank">
				<p class="tag" data-i18n="personal.pdfTag">PDF Placeholder</p>
				<h2 data-i18n="personal.coverTitle">Cover Letter / Letter of Intent</h2>
				<p data-i18n="personal.coverDescription">
					Placeholder letter PDF to be replaced with the final version.
				</p>
			</a>
		</div>
	</section>

	<section class="section">
		<p class="section-label" data-i18n="personal.socialsLabel">Socials</p>
		<div class="grid two">
			<a class="card link-card" href={LINKEDIN_URL} target="_blank" rel="noreferrer">
				<h2 data-i18n="personal.linkedinTitle">LinkedIn</h2>
				<p data-i18n="personal.linkedinDescription">
					Basic information, undergraduate degree, and SMU Guildhall education.
				</p>
			</a>
			<a class="card link-card" href={GITHUB_URL} target="_blank" rel="noreferrer">
				<h2 data-i18n="personal.githubTitle">GitHub</h2>
				<p data-i18n="personal.githubDescription">GitHub profile with README and project placeholder.</p>
			</a>
		</div>
	</section>
</PortfolioLayout>
