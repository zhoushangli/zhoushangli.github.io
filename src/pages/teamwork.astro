---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';

const projects = [
	{
		title: 'TGP I',
		video: 'https://www.youtube.com/embed/dQw4w9WgXcQ',
		descriptionKey: 'teamwork.tgp1Description',
		videoTitleKey: 'teamwork.tgp1VideoTitle',
		videoTitle: 'TGP I placeholder video',
		description:
			'TGP I is a placeholder for the first team game project. The final entry will include the project goal, team responsibilities, development process, and a trailer or gameplay video.',
	},
	{
		title: 'TGP II',
		video: 'https://www.youtube.com/embed/dQw4w9WgXcQ',
		descriptionKey: 'teamwork.tgp2Description',
		videoTitleKey: 'teamwork.tgp2VideoTitle',
		videoTitle: 'TGP II placeholder video',
		description:
			'TGP II is a placeholder for the second team game project. The final entry will focus on collaboration, iteration, production scope, and the work I contributed to the team.',
	},
];
---

<PortfolioLayout
	title="Team Projects | ShangLi Zhou"
	description="TGP I and TGP II teamwork portfolio entries by ShangLi Zhou."
>
	<section class="page-hero">
		<p class="eyebrow" data-i18n="teamwork.eyebrow">Teamwork</p>
		<h1 data-i18n="teamwork.title">Team Game Projects</h1>
		<p data-i18n="teamwork.intro">
			Two placeholder entries for TGP I and TGP II, prepared for final trailers, project details,
			and contribution summaries.
		</p>
	</section>

	<section class="section project-list">
		{
			projects.map((project) => (
				<article class="card project-card">
					<div class="video-frame">
						<iframe
							src={project.video}
							title={project.videoTitle}
							data-i18n-title={project.videoTitleKey}
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
						/>
					</div>
					<div>
						<p class="section-label" data-i18n="teamwork.label">
							Team Project
						</p>
						<h2>{project.title}</h2>
						<p data-i18n={project.descriptionKey}>{project.description}</p>
						<p>
							<strong data-i18n="teamwork.roleLabel">Role:</strong>{' '}
							<span data-i18n="teamwork.roleValue">
								Role placeholder: gameplay programmer / technical contributor
							</span>
						</p>
						<p>
							<strong data-i18n="teamwork.toolsLabel">Tools:</strong>{' '}
							<span data-i18n="teamwork.toolsValue">
								Tools placeholder: Unreal Engine, Unity, C++, C#, or team-selected tools
							</span>
						</p>
					</div>
				</article>
			))
		}
	</section>
</PortfolioLayout>
