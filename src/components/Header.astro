---
import { GITHUB_URL, LINKEDIN_URL } from '../consts';
import { getProjectsByCategory } from '../data/projects';

const personalProjects = getProjectsByCategory('personal');
const teamProjects = getProjectsByCategory('team');
---

<header>
	<nav>
		<h2><a href="/" data-i18n="nav.brand">SHANGLI ZHOU</a></h2>
		<div class="internal-links">
			<a href="/#about" data-i18n="nav.about">About</a>
			<a href="/#experience" data-i18n-inline data-en="Experience" data-zh="经历">Experience</a>

			<div class="nav-dropdown">
				<a
					href="/#personal-projects"
					data-i18n-inline
					data-en="Personal Projects"
					data-zh="个人项目">Personal Projects</a
				>
				<div class="dropdown-panel">
					{
						personalProjects.map((project) => (
							<a class="dropdown-link" href={`/projects/${project.slug}`}>
								{project.title}
							</a>
						))
					}
				</div>
			</div>

			<div class="nav-dropdown">
				<a href="/#team-projects" data-i18n="nav.teamwork">Team Projects</a>
				<div class="dropdown-panel">
					{
						teamProjects.map((project) => (
							<a class="dropdown-link" href={`/projects/${project.slug}`}>
								{project.title}
							</a>
						))
					}
				</div>
			</div>

			<a class="external-link" href={LINKEDIN_URL} target="_blank" rel="noreferrer" data-i18n="nav.linkedin"
				>LinkedIn</a
			>
			<a class="external-link" href={GITHUB_URL} target="_blank" rel="noreferrer" data-i18n="nav.github"
				>GitHub</a
			>
			<a class="external-link" href="/documents/resume-placeholder.pdf" target="_blank" data-i18n="nav.resume"
				>Resume</a
			>
			<button
				class="language-toggle"
				type="button"
				data-language-toggle
				data-i18n-aria-label="nav.languageToggleLabel"
				aria-label="Switch language to Chinese">
				<span class="language-dot"></span>
				<span data-i18n="nav.languageToggle">中文</span>
			</button>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid var(--border);
		background: rgba(14, 14, 15, 0.94);
		backdrop-filter: blur(16px);
	}
	h2 {
		margin: 0;
		font-size: 1.35rem;
		letter-spacing: 0;
		white-space: nowrap;
	}

	h2 a,
	h2 a.active {
		color: var(--text);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		min-height: 72px;
	}
	nav a {
		color: var(--muted);
		font-size: 1.1rem;
		text-decoration: none;
	}
	nav a.external-link {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.22em;
	}
	button.language-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		min-width: 58px;
		min-height: 42px;
		padding: 0.45rem 0.85rem;
		border: 1px solid rgba(190, 184, 172, 0.42);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.02);
		color: var(--text);
		box-shadow: inset 0 0 14px rgba(255, 255, 255, 0.05);
		font: inherit;
		font-size: 1.05rem;
		cursor: pointer;
	}
	.language-dot {
		width: 0.42rem;
		height: 0.42rem;
		border-radius: 999px;
		background: #8b5cf6;
		box-shadow: 0 0 10px rgba(139, 92, 246, 0.7);
	}
	nav a:hover,
	nav a.active,
	button.language-toggle:hover {
		color: var(--text);
		border-color: #55555f;
	}
	.internal-links {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: clamp(0.7rem, 2vw, 1.5rem);
		flex-wrap: wrap;
	}
	.nav-dropdown {
		position: relative;
		display: flex;
		align-items: center;
	}
	.dropdown-panel {
		position: absolute;
		top: calc(100% + 0.75rem);
		left: 0;
		z-index: 20;
		display: grid;
		min-width: 220px;
		padding: 0.8rem 0;
		border: 1px solid var(--border);
		background: rgba(22, 22, 24, 0.98);
		box-shadow:
			0 16px 30px rgba(0, 0, 0, 0.38),
			0 0 18px rgba(190, 184, 172, 0.08);
		opacity: 0;
		pointer-events: none;
		transform: translateY(-4px);
		transition:
			opacity 150ms ease,
			transform 150ms ease;
	}
	.nav-dropdown:hover .dropdown-panel,
	.nav-dropdown:focus-within .dropdown-panel {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
	}
	.dropdown-panel a.dropdown-link {
		padding: 0.65rem 1rem;
		color: var(--muted);
		white-space: nowrap;
	}
	.dropdown-panel a.dropdown-link:hover {
		color: var(--text);
		background: rgba(255, 255, 255, 0.04);
	}
	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding: 1rem 0;
		}
		.internal-links {
			justify-content: flex-start;
		}
		.nav-dropdown {
			align-items: flex-start;
			flex-direction: column;
		}
		.dropdown-panel {
			position: static;
			min-width: 0;
			padding: 0.25rem 0 0 0.75rem;
			border: 0;
			background: transparent;
			box-shadow: none;
			opacity: 1;
			pointer-events: auto;
			transform: none;
		}
	}
</style>
