---
import { GITHUB_URL, LINKEDIN_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">SHANGLI ZHOU</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">About</HeaderLink>
			<HeaderLink href="/individual-work">Individual Work</HeaderLink>
			<HeaderLink href="/teamwork">Team Projects</HeaderLink>
			<HeaderLink href="/personal">Personal</HeaderLink>
			<a href={LINKEDIN_URL} target="_blank" rel="noreferrer">LinkedIn</a>
			<a href={GITHUB_URL} target="_blank" rel="noreferrer">GitHub</a>
			<a href="/documents/resume-placeholder.pdf" target="_blank">Resume</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid var(--border);
		background: rgba(14, 14, 15, 0.94);
		backdrop-filter: blur(16px);
	}
	h2 {
		margin: 0;
		font-size: 1.05rem;
		letter-spacing: 0;
		white-space: nowrap;
	}

	h2 a,
	h2 a.active {
		color: var(--text);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		min-height: 72px;
	}
	nav a {
		color: var(--muted);
		text-decoration: none;
		font-size: 0.96rem;
	}
	nav a:hover,
	nav a.active {
		color: var(--text);
	}
	.internal-links {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: clamp(0.7rem, 2vw, 1.5rem);
		flex-wrap: wrap;
	}
	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding: 1rem 0;
		}
		.internal-links {
			justify-content: flex-start;
		}
	}
</style>
