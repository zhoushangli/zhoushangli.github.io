---
import { GITHUB_URL, LINKEDIN_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/" data-i18n="nav.brand">SHANGLI ZHOU</a></h2>
		<div class="internal-links">
			<HeaderLink href="/" data-i18n="nav.about">About</HeaderLink>
			<HeaderLink href="/individual-work" data-i18n="nav.individual">Individual Work</HeaderLink>
			<HeaderLink href="/teamwork" data-i18n="nav.teamwork">Team Projects</HeaderLink>
			<HeaderLink href="/personal" data-i18n="nav.personal">Personal</HeaderLink>
			<a href={LINKEDIN_URL} target="_blank" rel="noreferrer" data-i18n="nav.linkedin">LinkedIn</a>
			<a href={GITHUB_URL} target="_blank" rel="noreferrer" data-i18n="nav.github">GitHub</a>
			<a href="/documents/resume-placeholder.pdf" target="_blank" data-i18n="nav.resume">Resume</a>
			<button
				class="language-toggle"
				type="button"
				data-language-toggle
				data-i18n="nav.languageToggle"
				data-i18n-aria-label="nav.languageToggleLabel"
				aria-label="Switch language to Chinese">中文</button
			>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid var(--border);
		background: rgba(14, 14, 15, 0.94);
		backdrop-filter: blur(16px);
	}
	h2 {
		margin: 0;
		font-size: 1.35rem;
		letter-spacing: 0;
		white-space: nowrap;
	}

	h2 a,
	h2 a.active {
		color: var(--text);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		min-height: 72px;
	}
	nav a {
		font-size: 1.1rem;
	}
	button.language-toggle {
		min-width: 58px;
		min-height: 42px;
		padding: 0.45rem 0.85rem;
		font-size: 1.05rem;
	}
	nav a:hover,
	nav a.active,
	button.language-toggle:hover {
		color: var(--text);
		border-color: #55555f;
	}
	.internal-links {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: clamp(0.7rem, 2vw, 1.5rem);
		flex-wrap: wrap;
	}
	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding: 1rem 0;
		}
		.internal-links {
			justify-content: flex-start;
		}
	}
</style>
