---
import { GITHUB_URL, LINKEDIN_URL } from '../consts';
---

<header>
	<nav>
		<h2><a href="/" data-i18n="nav.brand">SHANGLI ZHOU</a></h2>
		<div class="internal-links">
			<a href="/#about" data-i18n="nav.about">About</a>
			<a href="/#experience" data-i18n-inline data-en="Experience" data-zh="经历">Experience</a>
			<a
				href="/#personal-projects"
				data-i18n-inline
				data-en="Personal Projects"
				data-zh="个人项目">Personal Projects</a
			>
			<a href="/#team-projects" data-i18n="nav.teamwork">Team Projects</a>
			<a class="external-link" href={LINKEDIN_URL} target="_blank" rel="noreferrer" data-i18n="nav.linkedin"
				>LinkedIn</a
			>
			<a class="external-link" href={GITHUB_URL} target="_blank" rel="noreferrer" data-i18n="nav.github"
				>GitHub</a
			>
			<a class="external-link" href="/documents/resume-placeholder.pdf" target="_blank" data-i18n="nav.resume"
				>Resume</a
			>
			<button
				class="language-toggle"
				type="button"
				data-language-toggle
				data-i18n="nav.languageToggle"
				data-i18n-aria-label="nav.languageToggleLabel"
				aria-label="Switch language to Chinese">中文</button
			>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid var(--border);
		background: rgba(14, 14, 15, 0.94);
		backdrop-filter: blur(16px);
	}
	h2 {
		margin: 0;
		font-size: 1.35rem;
		letter-spacing: 0;
		white-space: nowrap;
	}

	h2 a,
	h2 a.active {
		color: var(--text);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		min-height: 72px;
	}
	nav a {
		font-size: 1.1rem;
		color: var(--muted);
		text-decoration: none;
	}
	nav a.external-link {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.22em;
	}
	button.language-toggle {
		min-width: 58px;
		min-height: 42px;
		padding: 0.45rem 0.85rem;
		font-size: 1.05rem;
	}
	nav a:hover,
	nav a.active,
	button.language-toggle:hover {
		color: var(--text);
		border-color: #55555f;
	}
	.internal-links {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: clamp(0.7rem, 2vw, 1.5rem);
		flex-wrap: wrap;
	}
	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding: 1rem 0;
		}
		.internal-links {
			justify-content: flex-start;
		}
	}
</style>
