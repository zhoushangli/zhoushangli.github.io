---
import { GITHUB_URL, LINKEDIN_URL } from '../consts';
import { getProjectsByCategory } from '../data/projects';

const personalProjects = getProjectsByCategory('personal');
const teamProjects = getProjectsByCategory('team');
---

<header>
	<nav>
		<h2><a href="/" data-i18n="nav.brand">SHANGLI ZHOU</a></h2>
		<div class="internal-links">
			<a href="/#about" data-i18n="nav.about">About</a>
			<a href="/#experience" data-i18n-inline data-en="Experience" data-zh="经历">Experience</a>

			<div class="nav-dropdown">
				<a
					href="/#personal-projects"
					data-i18n-inline
					data-en="Personal Projects"
					data-zh="个人项目">Personal Projects</a
				>
				<div class="dropdown-panel">
					{
						personalProjects.map((project) => (
							<a class="dropdown-link" href={`/projects/${project.slug}`}>
								{project.title}
							</a>
						))
					}
				</div>
			</div>

			<div class="nav-dropdown">
				<a href="/#team-projects" data-i18n="nav.teamwork">Team Projects</a>
				<div class="dropdown-panel">
					{
						teamProjects.map((project) => (
							<a class="dropdown-link" href={`/projects/${project.slug}`}>
								{project.title}
							</a>
						))
					}
				</div>
			</div>

			<a class="external-link" href={LINKEDIN_URL} target="_blank" rel="noreferrer" data-i18n="nav.linkedin"
				>LinkedIn</a
			>
			<a class="external-link" href={GITHUB_URL} target="_blank" rel="noreferrer" data-i18n="nav.github"
				>GitHub</a
			>
			<a class="external-link" href="/documents/resume-placeholder.pdf" target="_blank" data-i18n="nav.resume"
				>Resume</a
			>
			<button
				class="theme-toggle"
				type="button"
				data-theme-toggle
				aria-label="Switch to light theme">
				<span data-theme-toggle-icon>☀</span>
			</button>
			<button
				class="language-toggle"
				type="button"
				data-language-toggle
				data-i18n-aria-label="nav.languageToggleLabel"
				aria-label="Switch language to Chinese">
				<span class="language-dot"></span>
				<span data-i18n="nav.languageToggle">中文</span>
			</button>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid var(--border);
		background:
			linear-gradient(180deg, var(--topbar-highlight), transparent 38%),
			var(--topbar-bg);
		box-shadow:
			inset 0 1px 0 var(--highlight),
			inset 0 -1px 0 var(--topbar-inset),
			0 12px 28px var(--shadow-dark);
		backdrop-filter: blur(18px);
	}
	header::after {
		position: absolute;
		right: 0;
		bottom: -1px;
		left: 0;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			var(--line-soft),
			var(--line-bright),
			var(--line-soft),
			transparent
		);
		content: '';
		pointer-events: none;
	}
	h2 {
		margin: 0;
		font-size: 1.35rem;
		letter-spacing: 0;
		white-space: nowrap;
	}

	h2 a,
	h2 a.active {
		color: var(--text);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		min-height: 72px;
	}
	nav a {
		position: relative;
		color: var(--muted);
		font-size: 1.1rem;
		text-decoration: none;
		text-shadow: none;
	}
	nav a::after {
		position: absolute;
		right: 0;
		bottom: -0.35rem;
		left: 0;
		height: 1px;
		background: var(--accent);
		content: '';
		opacity: 0;
		transform: scaleX(0.35);
		transition:
			opacity 150ms ease,
			transform 150ms ease;
	}
	nav a.external-link {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.22em;
	}
	nav a.external-link::after,
	h2 a::after,
	.dropdown-panel a::after {
		display: none;
	}
	button.language-toggle,
	button.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		min-height: 42px;
		padding: 0.45rem 0.85rem;
		border: 1px solid var(--control-border);
		border-radius: 8px;
		background:
			linear-gradient(180deg, var(--topbar-highlight), transparent),
			var(--control-bg);
		color: var(--text);
		box-shadow:
			inset 0 1px 0 var(--highlight),
			inset 0 -1px 0 var(--topbar-inset);
		font: inherit;
		font-size: 1.05rem;
		cursor: pointer;
	}
	button.language-toggle {
		min-width: 58px;
	}
	button.theme-toggle {
		width: 42px;
		min-width: 42px;
		padding: 0;
		font-size: 1.12rem;
		line-height: 1;
	}
	.language-dot {
		width: 0.42rem;
		height: 0.42rem;
		border-radius: 999px;
		background: var(--accent);
		box-shadow: inset 0 1px 0 var(--highlight);
	}
	nav a:hover,
	nav a.active,
	button.language-toggle:hover,
	button.theme-toggle:hover {
		color: var(--text);
		border-color: var(--brass-soft);
		text-shadow: none;
	}
	nav a:hover::after,
	nav a.active::after {
		opacity: 1;
		transform: scaleX(1);
	}
	.internal-links {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: clamp(0.7rem, 2vw, 1.5rem);
		flex-wrap: wrap;
	}
	.nav-dropdown {
		position: relative;
		display: flex;
		align-items: center;
	}
	.dropdown-panel {
		position: absolute;
		top: calc(100% + 0.75rem);
		left: 0;
		z-index: 20;
		display: grid;
		min-width: 220px;
		padding: 0.8rem 0;
		border: 1px solid var(--control-border);
		background:
			linear-gradient(180deg, var(--topbar-highlight), transparent 32%),
			var(--dropdown-bg);
		box-shadow:
			inset 0 1px 0 var(--highlight),
			inset 0 -1px 0 var(--topbar-inset),
			0 16px 30px var(--shadow-dark);
		opacity: 0;
		pointer-events: none;
		transform: translateY(-4px);
		transition:
			opacity 150ms ease,
			transform 150ms ease;
	}
	.dropdown-panel::before {
		position: absolute;
		right: 0;
		bottom: 100%;
		left: 0;
		height: 0.75rem;
		content: '';
	}
	.nav-dropdown:hover .dropdown-panel,
	.nav-dropdown:focus-within .dropdown-panel {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
	}
	.dropdown-panel a.dropdown-link {
		padding: 0.65rem 1rem;
		color: var(--muted);
		white-space: nowrap;
	}
	.dropdown-panel a.dropdown-link:hover,
	.dropdown-panel a.dropdown-link:focus-visible {
		color: var(--text);
		background: var(--thumbnail-mark);
		outline: none;
	}
	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding: 1rem 0;
		}
		.internal-links {
			justify-content: flex-start;
		}
		.nav-dropdown {
			align-items: flex-start;
			flex-direction: column;
		}
		.dropdown-panel {
			position: static;
			min-width: 0;
			padding: 0.25rem 0 0 0.75rem;
			border: 0;
			background: transparent;
			box-shadow: none;
			opacity: 1;
			pointer-events: auto;
			transform: none;
		}
	}
</style>
