---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { copy } from '../i18n/copy';

interface Props {
	title?: string;
	description?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<script is:inline>
			(() => {
				try {
					const theme = localStorage.getItem('portfolio-theme');
					if (theme === 'dark' || theme === 'light') {
						document.documentElement.setAttribute('data-theme', theme);
					}
				} catch {
					// Keep the default dark theme if storage is unavailable.
				}
			})();
		</script>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		<script define:vars={{ copy }}>
			const storageKey = 'portfolio-language';
			const themeStorageKey = 'portfolio-theme';
			const languages = ['en', 'zh'];
			const themes = ['dark', 'light'];

			function getValue(source, path) {
				return path.split('.').reduce((value, part) => value?.[part], source);
			}

			function normalizeLanguage(language) {
				return languages.includes(language) ? language : 'en';
			}

			function normalizeTheme(theme) {
				return themes.includes(theme) ? theme : 'dark';
			}

			function getStoredLanguage() {
				try {
					return normalizeLanguage(localStorage.getItem(storageKey));
				} catch {
					return 'en';
				}
			}

			function getStoredTheme() {
				try {
					return normalizeTheme(localStorage.getItem(themeStorageKey));
				} catch {
					return 'dark';
				}
			}

			function setStoredLanguage(language) {
				try {
					localStorage.setItem(storageKey, language);
				} catch {
					// Ignore storage failures and still update the current page.
				}
			}

			function setStoredTheme(theme) {
				try {
					localStorage.setItem(themeStorageKey, theme);
				} catch {
					// Ignore storage failures and still update the current page.
				}
			}

			function applyTheme(theme) {
				const activeTheme = normalizeTheme(theme);
				const nextTheme = activeTheme === 'dark' ? 'light' : 'dark';
				const icon = activeTheme === 'dark' ? '☀' : '☾';
				const label = `Switch to ${nextTheme} theme`;

				document.documentElement.setAttribute('data-theme', activeTheme);

				document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
					button.setAttribute('aria-label', label);
					button.setAttribute('data-theme', activeTheme);
				});

				document.querySelectorAll('[data-theme-toggle-icon]').forEach((element) => {
					element.textContent = icon;
				});
			}

			function applyLanguage(language) {
				const activeLanguage = normalizeLanguage(language);
				const activeCopy = copy[activeLanguage];

				document.documentElement.lang = activeLanguage === 'zh' ? 'zh-CN' : 'en';

				document.querySelectorAll('[data-i18n]').forEach((element) => {
					const key = element.getAttribute('data-i18n');
					const value = key ? getValue(activeCopy, key) : undefined;
					if (typeof value === 'string') {
						element.textContent = value;
					}
				});

				document.querySelectorAll('[data-i18n-html]').forEach((element) => {
					const key = element.getAttribute('data-i18n-html');
					const value = key ? getValue(activeCopy, key) : undefined;
					if (typeof value === 'string') {
						element.innerHTML = value;
					}
				});

				document.querySelectorAll('[data-i18n-inline]').forEach((element) => {
					const value = element.getAttribute(activeLanguage === 'zh' ? 'data-zh' : 'data-en');
					if (typeof value === 'string') {
						element.textContent = value;
					}
				});

				document.querySelectorAll('[data-i18n-inline-html]').forEach((element) => {
					const value = element.getAttribute(activeLanguage === 'zh' ? 'data-zh' : 'data-en');
					if (typeof value === 'string') {
						element.innerHTML = value;
					}
				});

				document.querySelectorAll('[data-i18n-inline-alt]').forEach((element) => {
					const value = element.getAttribute(activeLanguage === 'zh' ? 'data-zh' : 'data-en');
					if (typeof value === 'string') {
						element.setAttribute('alt', value);
					}
				});

				document.querySelectorAll('[data-i18n-inline-title]').forEach((element) => {
					const value = element.getAttribute(activeLanguage === 'zh' ? 'data-zh' : 'data-en');
					if (typeof value === 'string') {
						element.setAttribute('title', value);
					}
				});

				document.querySelectorAll('[data-i18n-alt]').forEach((element) => {
					const key = element.getAttribute('data-i18n-alt');
					const value = key ? getValue(activeCopy, key) : undefined;
					if (typeof value === 'string') {
						element.setAttribute('alt', value);
					}
				});

				document.querySelectorAll('[data-i18n-title]').forEach((element) => {
					const key = element.getAttribute('data-i18n-title');
					const value = key ? getValue(activeCopy, key) : undefined;
					if (typeof value === 'string') {
						element.setAttribute('title', value);
					}
				});

				document.querySelectorAll('[data-i18n-aria-label]').forEach((element) => {
					const key = element.getAttribute('data-i18n-aria-label');
					const value = key ? getValue(activeCopy, key) : undefined;
					if (typeof value === 'string') {
						element.setAttribute('aria-label', value);
					}
				});

				document.querySelectorAll('[data-language-toggle]').forEach((button) => {
					button.setAttribute('data-language', activeLanguage);
				});
			}

			function toggleLanguage() {
				const nextLanguage = getStoredLanguage() === 'zh' ? 'en' : 'zh';
				setStoredLanguage(nextLanguage);
				applyLanguage(nextLanguage);
			}

			function toggleTheme() {
				const nextTheme = getStoredTheme() === 'dark' ? 'light' : 'dark';
				setStoredTheme(nextTheme);
				applyTheme(nextTheme);
			}

			window.setPortfolioLanguage = (language) => {
				const nextLanguage = normalizeLanguage(language);
				setStoredLanguage(nextLanguage);
				applyLanguage(nextLanguage);
			};

			document.addEventListener('click', (event) => {
				if (!(event.target instanceof Element)) {
					return;
				}

				const toggle = event.target.closest('[data-language-toggle]');
				if (toggle) {
					toggleLanguage();
					return;
				}

				const themeToggle = event.target.closest('[data-theme-toggle]');
				if (themeToggle) {
					toggleTheme();
				}
			});

			applyTheme(getStoredTheme());
			applyLanguage(getStoredLanguage());
		</script>
	</body>
</html>
