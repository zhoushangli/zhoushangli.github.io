---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { copy } from '../i18n/copy';

interface Props {
	title?: string;
	description?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		<script define:vars={{ copy }}>
			const storageKey = 'portfolio-language';
			const languages = ['en', 'zh'];

			function getValue(source, path) {
				return path.split('.').reduce((value, part) => value?.[part], source);
			}

			function normalizeLanguage(language) {
				return languages.includes(language) ? language : 'en';
			}

			function getStoredLanguage() {
				try {
					return normalizeLanguage(localStorage.getItem(storageKey));
				} catch {
					return 'en';
				}
			}

			function setStoredLanguage(language) {
				try {
					localStorage.setItem(storageKey, language);
				} catch {
					// Ignore storage failures and still update the current page.
				}
			}

			function applyLanguage(language) {
				const activeLanguage = normalizeLanguage(language);
				const activeCopy = copy[activeLanguage];

				document.documentElement.lang = activeLanguage === 'zh' ? 'zh-CN' : 'en';

				document.querySelectorAll('[data-i18n]').forEach((element) => {
					const key = element.getAttribute('data-i18n');
					const value = key ? getValue(activeCopy, key) : undefined;
					if (typeof value === 'string') {
						element.textContent = value;
					}
				});

				document.querySelectorAll('[data-i18n-alt]').forEach((element) => {
					const key = element.getAttribute('data-i18n-alt');
					const value = key ? getValue(activeCopy, key) : undefined;
					if (typeof value === 'string') {
						element.setAttribute('alt', value);
					}
				});

				document.querySelectorAll('[data-i18n-title]').forEach((element) => {
					const key = element.getAttribute('data-i18n-title');
					const value = key ? getValue(activeCopy, key) : undefined;
					if (typeof value === 'string') {
						element.setAttribute('title', value);
					}
				});

				document.querySelectorAll('[data-i18n-aria-label]').forEach((element) => {
					const key = element.getAttribute('data-i18n-aria-label');
					const value = key ? getValue(activeCopy, key) : undefined;
					if (typeof value === 'string') {
						element.setAttribute('aria-label', value);
					}
				});

				document.querySelectorAll('[data-language-toggle]').forEach((button) => {
					button.setAttribute('data-language', activeLanguage);
				});
			}

			function toggleLanguage() {
				const nextLanguage = getStoredLanguage() === 'zh' ? 'en' : 'zh';
				setStoredLanguage(nextLanguage);
				applyLanguage(nextLanguage);
			}

			window.setPortfolioLanguage = (language) => {
				const nextLanguage = normalizeLanguage(language);
				setStoredLanguage(nextLanguage);
				applyLanguage(nextLanguage);
			};

			document.addEventListener('click', (event) => {
				if (!(event.target instanceof Element)) {
					return;
				}

				const toggle = event.target.closest('[data-language-toggle]');
				if (toggle) {
					toggleLanguage();
				}
			});

			applyLanguage(getStoredLanguage());
		</script>
	</body>
</html>
